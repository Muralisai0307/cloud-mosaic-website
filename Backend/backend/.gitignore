# pyenv
#   For a library or app, you might want to share your .python-version if you intend
#   to associate a specific version of Python with your project.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all dependencies.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the exact dependency versions and should
#   typically be committed.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the exact dependency versions and should
#   typically be committed.
#.pdm.toml
#.pdm-python
#.pdm-build/

# PEP 582; dependency directory created by pipflow via `pipflow install`
__pypackages__/

